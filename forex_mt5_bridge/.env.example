# Redis Connection (If MT5 Bridge is on a different machine than Docker VPS, set public IP/Host)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# MetaTrader 5 Credentials (ensure Terminal is installed and logged in on this Windows machine)
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password_here
MT5_SERVER=YourBroker-Demo