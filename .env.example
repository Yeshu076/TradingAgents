# LLM Providers (set at least one)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Market data providers
ALPHA_VANTAGE_API_KEY=

# Delta Exchange crypto derivatives provider
DELTA_REST_BASE_URL=https://api.india.delta.exchange
DELTA_API_KEY=
DELTA_API_SECRET=

# Dhan provider (Nifty options chain)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_NIFTY_SECURITY_ID=13
DHAN_NIFTY_UNDERLYING_SEGMENT=IDX_I

# Execution guardrails
TRADINGAGENTS_ALLOW_LIVE=false
TRADINGAGENTS_MAX_ORDER_QTY=25
TRADINGAGENTS_MAX_ORDER_NOTIONAL=500000
TRADINGAGENTS_MAX_DAILY_TRADES=50
TRADINGAGENTS_ALLOWED_INSTRUMENTS=options,spot,crypto,forex,equity
TRADINGAGENTS_ENFORCE_MARKET_HOURS=true

# Deterministic risk gate (pre-execution)
TRADINGAGENTS_RISK_MIN_CONFIDENCE=0.40
TRADINGAGENTS_RISK_MIN_RR=1.20
TRADINGAGENTS_RISK_MAX_POSITION_PCT=0.15

# Local paper wallet
TRADINGAGENTS_PAPER_INITIAL_BALANCE=1000000
TRADINGAGENTS_PAPER_STATE_FILE=paper_wallet.json

# Execution idempotency (prevents accidental duplicate orders)
TRADINGAGENTS_EXECUTION_IDEMPOTENCY_ENABLED=true
TRADINGAGENTS_EXECUTION_IDEMPOTENCY_WINDOW_SECONDS=3600
TRADINGAGENTS_EXECUTION_IDEMPOTENCY_SCAN_LIMIT=1000

# Broker/API resilience controls
TRADINGAGENTS_RETRY_MAX_ATTEMPTS=3
TRADINGAGENTS_RETRY_BASE_DELAY_SECONDS=0.25
TRADINGAGENTS_RETRY_MAX_DELAY_SECONDS=2.0
TRADINGAGENTS_RETRY_JITTER_RATIO=0.15
TRADINGAGENTS_CIRCUIT_FAILURE_THRESHOLD=3
TRADINGAGENTS_CIRCUIT_RESET_SECONDS=60
TRADINGAGENTS_HTTP_TIMEOUT_SECONDS=15

# Emergency kill switch
# Max seconds to wait for each broker's cancel_all_orders() call during shutdown.
# Lower values make the kill switch faster but may miss in-flight cancels.
KILLSWITCH_CANCEL_TIMEOUT_SECONDS=10

# Append-only execution decision journal
TRADINGAGENTS_DECISION_JOURNAL_FILE=trade_decisions.jsonl
TRADINGAGENTS_DECISION_JOURNAL_ROTATE_DAILY=true
TRADINGAGENTS_DECISION_JOURNAL_MAX_BYTES=5000000
TRADINGAGENTS_DECISION_JOURNAL_MAX_ROLL_FILES=5

# Notifications (leave blank to disable)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
